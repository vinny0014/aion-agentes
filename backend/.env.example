# AION AI NEWS OS — Backend
# Copie para .env e preencha. NUNCA versione o .env.

APP_NAME=AION AI NEWS OS
ENV=development
DATABASE_URL=sqlite:///./aion.db
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ADMIN_SETUP_TOKEN=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173

# Provedores de IA (opcional — sem um provedor, o pipeline cria drafts offline)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=

SITE_URL=https://aion-news-os.vercel.app
PUBLIC_API_URL=https://aion-news-api.onrender.com
UPLOAD_DIR=./uploads
IMAGE_PROVIDER=pollinations
