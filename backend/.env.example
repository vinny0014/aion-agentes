# AION AGENTES — Backend
# Copie para .env e preencha. NUNCA versione o .env.

APP_NAME=AION AGENTES
ENV=development
DATABASE_URL=sqlite:///./aion.db
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173

# Provedores de IA (opcional — pipeline fica bloqueado até configurar ao menos um)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
