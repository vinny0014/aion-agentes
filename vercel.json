{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "https://aion-news-api.onrender.com/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://aion-news-api.onrender.com/sitemap.xml"
    },
    {
      "source": "/news-sitemap.xml",
      "destination": "https://aion-news-api.onrender.com/news-sitemap.xml"
    },
    {
      "source": "/image-sitemap.xml",
      "destination": "https://aion-news-api.onrender.com/image-sitemap.xml"
    },
    {
      "source": "/rss.xml",
      "destination": "https://aion-news-api.onrender.com/rss.xml"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(logo.png|og-cover.png|favicon.svg|ads.txt)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}