{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "https://aion-news-api.onrender.com/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://aion-news-api.onrender.com/sitemap.xml"
    },
    {
      "source": "/news-sitemap.xml",
      "destination": "https://aion-news-api.onrender.com/news-sitemap.xml"
    },
    {
      "source": "/rss.xml",
      "destination": "https://aion-news-api.onrender.com/rss.xml"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}